{
  "name": "paypal-payment-integration",
  "version": "1.5.0",
  "description": "Paypal Payment integration",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/main.js",
    "start:dev": "node_modules/.bin/nodemon -q dist/main.js",
    "lint": "prettier --check \"**/**/*.{ts,js,json}\" && eslint src",
    "lint:fix": "prettier --write \"**/**/*.{ts,js,json}\" && eslint --fix src",
    "build": "rm -rf /dist && tsc",
    "dev": "ts-node src/main.ts",
    "watch": "nodemon --watch \"src/**\" --ext \"ts,json\" --ignore \"src/**/*.spec.ts\" --exec \"ts-node src/main.ts\"",
    "test": "jest --detectOpenHandles",
    "test:watch": "jest --watch --detectOpenHandles",
    "connector:post-deploy": "node dist/connectors/post-deploy.js",
    "connector:pre-undeploy": "node dist/connectors/pre-undeploy.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@commercetools-backend/loggers": "24.2.1",
    "@commercetools/connect-payments-sdk": "0.23.1",
    "@fastify/autoload": "6.3.1",
    "@fastify/cors": "11.2.0",
    "@fastify/formbody": "8.0.2",
    "@fastify/http-proxy": "11.5.0",
    "@fastify/request-context": "7.0.0",
    "@fastify/static": "9.1.3",
    "@fastify/type-provider-typebox": "6.1.0",
    "@sinclair/typebox": "0.33.22",
    "dotenv": "17.4.2",
    "fastify": "5.9.0",
    "fastify-plugin": "5.0.1"
  },
  "devDependencies": {
    "@jest/globals": "30.4.1",
    "@types/jest": "30.0.0",
    "@types/node": "24.0.15",
    "@typescript-eslint/eslint-plugin": "8.62.0",
    "@typescript-eslint/parser": "8.62.0",
    "eslint": "9.31.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jest": "29.15.3",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-unused-imports": "4.4.1",
    "jest": "30.4.2",
    "msw": "2.14.6",
    "node-fetch": "3.3.2",
    "nodemon": "3.1.14",
    "prettier": "3.9.3",
    "ts-jest": "29.4.11",
    "ts-node": "10.9.2",
    "typescript": "5.8.3"
  },
  "overrides": {
    "path-to-regexp": "3.3.0"
  }
}
